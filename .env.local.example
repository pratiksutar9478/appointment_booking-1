# ──────────────────────────────────────────────────────────────
# Firebase (required)
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ──────────────────────────────────────────────────────────────
# Twilio (required for messaging)
# ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Your Twilio phone number (for SMS)  e.g. +15005550006
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# For WhatsApp:
#   Sandbox  → +14155238886 (default — patients must first text "join <word>" to this number)
#   Business → your approved WhatsApp Business number
TWILIO_WHATSAPP_NUMBER=+14155238886

# ──────────────────────────────────────────────────────────────
# Hospital info (shown inside messages)
# ──────────────────────────────────────────────────────────────
HOSPITAL_NAME=City General Hospital
HOSPITAL_PHONE=+1-800-HOSPITAL

# ──────────────────────────────────────────────────────────────
# Cron security (add to Authorization header when calling /api/reminders)
# ──────────────────────────────────────────────────────────────
CRON_SECRET=replace_with_a_long_random_string
